{
  "Function Definition": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "\t${0:// implementation}",
      "}"
    ],
    "description": "Define a new function"
  },
  "Async Function": {
    "prefix": "async-fn",
    "body": [
      "async fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "\t${0:// async implementation}",
      "}"
    ],
    "description": "Define an async function"
  },
  "Function with Contexts": {
    "prefix": "fn-using",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} using [${4:Context}] {",
      "\t${0:// implementation}",
      "}"
    ],
    "description": "Function with context dependencies (using clause)"
  },
  "Function with Generics": {
    "prefix": "fn-generic",
    "body": [
      "fn ${1:name}<${2:T}>(${3:params}: ${2:T}) -> ${4:ReturnType} {",
      "\t${0:// implementation}",
      "}"
    ],
    "description": "Generic function"
  },
  "Function with where Constraints": {
    "prefix": "fn-where",
    "body": [
      "fn ${1:name}<${2:T}>(${3:params}: ${2:T}) -> ${4:ReturnType}",
      "where ${2:T}: ${5:Protocol} {",
      "\t${0:// implementation}",
      "}"
    ],
    "description": "Generic function with protocol bound"
  },
  "Function with Precondition": {
    "prefix": "fn-requires",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType}",
      "\trequires ${4:condition}",
      "{",
      "\t${0:// implementation}",
      "}"
    ],
    "description": "Function with precondition"
  },
  "Function with Postcondition": {
    "prefix": "fn-ensures",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType}",
      "\tensures ${4:result_condition}",
      "{",
      "\t${0:// implementation}",
      "}"
    ],
    "description": "Function with postcondition"
  },
  "Function with Full Contract": {
    "prefix": "fn-contract",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType}",
      "\trequires ${4:precondition}",
      "\tensures ${5:postcondition}",
      "{",
      "\t${0:// implementation}",
      "}"
    ],
    "description": "Function with requires + ensures"
  },
  "Function with throws": {
    "prefix": "fn-throws",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} throws ${4:ErrorType} {",
      "\t${0:// implementation}",
      "}"
    ],
    "description": "Function with typed error boundary"
  },
  "Pure Function": {
    "prefix": "fn-pure",
    "body": [
      "pure fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "\t${0:// compiler-verified no side effects}",
      "}"
    ],
    "description": "Pure function (compiler-verified)"
  },
  "Verify Static": {
    "prefix": "fn-verify-static",
    "body": [
      "@verify(static)",
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "\t${0:// implementation}",
      "}"
    ],
    "description": "Function verified by static checks only"
  },
  "Verify Runtime": {
    "prefix": "fn-verify-runtime",
    "body": [
      "@verify(runtime)",
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "\t${0:// implementation}",
      "}"
    ],
    "description": "Function with runtime contract checks"
  },
  "Verify Formal": {
    "prefix": "fn-verify-formal",
    "body": [
      "@verify(formal)",
      "fn ${1:name}(${2:params}) -> ${3:ReturnType}",
      "\trequires ${4:precondition}",
      "\tensures ${5:postcondition}",
      "{",
      "\t${0:// implementation}",
      "}"
    ],
    "description": "Function with formal proof verification"
  },
  "Verify Thorough": {
    "prefix": "fn-verify-thorough",
    "body": [
      "@verify(thorough)",
      "fn ${1:name}(${2:params}) -> ${3:ReturnType}",
      "\tensures ${4:postcondition}",
      "{",
      "\t${0:// implementation}",
      "}"
    ],
    "description": "Function verified with thorough strategy (races solvers)"
  },
  "Verify Certified": {
    "prefix": "fn-verify-certified",
    "body": [
      "@verify(certified)",
      "fn ${1:name}(${2:params}) -> ${3:ReturnType}",
      "\tensures ${4:postcondition}",
      "{",
      "\t${0:// cross-verified by orthogonal techniques}",
      "}"
    ],
    "description": "Function cross-verified for export to Coq/Lean"
  },
  "Main Function": {
    "prefix": "main",
    "body": [
      "@std",
      "fn main() {",
      "\t${0:// entry point}",
      "}"
    ],
    "description": "Main entry point with @std attribute"
  },
  "Main with Contexts": {
    "prefix": "main-ctx",
    "body": [
      "@std(${1:ServerContext})",
      "fn main() {",
      "\t${0:// entry point with contexts}",
      "}"
    ],
    "description": "Main entry point with context group"
  },
  "Meta Function": {
    "prefix": "meta-fn",
    "body": [
      "meta fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "\t${0:// compile-time computation}",
      "}"
    ],
    "description": "Compile-time meta function"
  },

  "Type Alias": {
    "prefix": "type",
    "body": [
      "type ${1:Name} is ${2:BaseType};"
    ],
    "description": "Type alias"
  },
  "Record Type": {
    "prefix": "type-record",
    "body": [
      "type ${1:Name} is {",
      "\t${2:field1}: ${3:Type1},",
      "\t${4:field2}: ${5:Type2},",
      "};"
    ],
    "description": "Record type"
  },
  "Variant (Sum) Type": {
    "prefix": "type-variant",
    "body": [
      "type ${1:Name} is",
      "\t  ${2:Variant1}",
      "\t| ${3:Variant2}(${4:Type})",
      "\t| ${5:Variant3} { ${6:field}: ${7:Type} };"
    ],
    "description": "Variant / sum type"
  },
  "Generic Type": {
    "prefix": "type-generic",
    "body": [
      "type ${1:Name}<${2:T}> is ${3:BaseType}<${2:T}>;"
    ],
    "description": "Generic type"
  },
  "Newtype Wrapper": {
    "prefix": "type-newtype",
    "body": [
      "type ${1:Name} is (${2:BaseType});"
    ],
    "description": "Newtype wrapper (opaque unary tuple)"
  },
  "Unit Type": {
    "prefix": "type-unit",
    "body": [
      "type ${1:Marker} is ();"
    ],
    "description": "Unit marker type"
  },
  "Refinement (Inline)": {
    "prefix": "type-refined",
    "body": [
      "type ${1:Name} is ${2:BaseType} { ${3:self > 0} };"
    ],
    "description": "Refinement type with inline predicate (uses `self`)"
  },
  "Positive Integer": {
    "prefix": "positive",
    "body": [
      "type Positive is Int { self > 0 };"
    ],
    "description": "Positive integer refinement"
  },
  "Non-Zero Integer": {
    "prefix": "nonzero",
    "body": [
      "type NonZero is Int { self != 0 };"
    ],
    "description": "Non-zero integer refinement"
  },
  "Bounded Integer": {
    "prefix": "bounded",
    "body": [
      "type ${1:Name} is Int { ${2:0} <= self && self <= ${3:100} };"
    ],
    "description": "Bounded integer refinement"
  },
  "Non-Empty List": {
    "prefix": "non-empty-list",
    "body": [
      "type NonEmpty<T> is List<T> { self.len() > 0 };"
    ],
    "description": "Non-empty list refinement"
  },
  "Email Refinement": {
    "prefix": "type-email",
    "body": [
      "type Email is Text { self.matches(rx#\"^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$\") };"
    ],
    "description": "Email-shaped text refinement"
  },
  "Port Refinement": {
    "prefix": "type-port",
    "body": [
      "type Port is Int { 1 <= self && self <= 65535 };"
    ],
    "description": "TCP port refinement"
  },
  "Tensor Type": {
    "prefix": "type-tensor",
    "body": [
      "type ${1:Matrix} is Tensor<${2:f32}, [${3:M}, ${4:N}]>;"
    ],
    "description": "Tensor with dimension shape"
  },

  "Protocol Definition": {
    "prefix": "protocol",
    "body": [
      "type ${1:Name} is protocol {",
      "\tfn ${2:method}(&self${3:, params}) -> ${4:ReturnType};",
      "}"
    ],
    "description": "Protocol (trait) definition"
  },
  "Protocol with Associated Type": {
    "prefix": "protocol-assoc",
    "body": [
      "type ${1:Iterator} is protocol {",
      "\ttype Item;",
      "\tfn ${2:next}(&mut self) -> Maybe<Self.Item>;",
      "}"
    ],
    "description": "Protocol with associated type"
  },
  "Context Protocol": {
    "prefix": "context-protocol",
    "body": [
      "context protocol ${1:Name} {",
      "\tfn ${2:method}(&self${3:, params}) -> ${4:ReturnType};",
      "}"
    ],
    "description": "Dual-kind context protocol"
  },
  "Implement Protocol for Type": {
    "prefix": "impl",
    "body": [
      "implement ${1:Protocol} for ${2:Type} {",
      "\tfn ${3:method}(${4:params}) -> ${5:ReturnType} {",
      "\t\t${0:// implementation}",
      "\t}",
      "}"
    ],
    "description": "Implementation block"
  },
  "Implement Inherent Methods": {
    "prefix": "impl-inherent",
    "body": [
      "implement ${1:Type} {",
      "\tfn ${2:method}(${3:params}) -> ${4:ReturnType} {",
      "\t\t${0:// implementation}",
      "\t}",
      "}"
    ],
    "description": "Inherent methods on a type"
  },
  "Implement Generic": {
    "prefix": "impl-generic",
    "body": [
      "implement<${1:T}> ${2:Protocol} for ${3:Type}<${1:T}> {",
      "\tfn ${4:method}(${5:params}) -> ${6:ReturnType} {",
      "\t\t${0:// implementation}",
      "\t}",
      "}"
    ],
    "description": "Generic implementation"
  },
  "Implement with Bounds": {
    "prefix": "impl-where",
    "body": [
      "implement<${1:T}> ${2:Protocol} for ${3:Type}<${1:T}>",
      "where ${1:T}: ${4:Bound} {",
      "\tfn ${5:method}(${6:params}) -> ${7:ReturnType} {",
      "\t\t${0:// implementation}",
      "\t}",
      "}"
    ],
    "description": "Implementation with where clause"
  },
  "Specialized Implementation": {
    "prefix": "impl-specialize",
    "body": [
      "@specialize",
      "implement ${1:Protocol} for ${2:Type} {",
      "\tfn ${3:method}(${4:params}) -> ${5:ReturnType} {",
      "\t\t${0:// specialized implementation}",
      "\t}",
      "}"
    ],
    "description": "Specialized implementation"
  },

  "Context Definition": {
    "prefix": "context",
    "body": [
      "context ${1:Name} {",
      "\tfn ${2:method}(${3:params}) -> ${4:ReturnType};",
      "}"
    ],
    "description": "Context (dependency) definition"
  },
  "Async Context": {
    "prefix": "context-async",
    "body": [
      "async context ${1:Name} {",
      "\tasync fn ${2:method}(${3:params}) -> ${4:ReturnType};",
      "}"
    ],
    "description": "Async context definition"
  },
  "Provide Context": {
    "prefix": "provide",
    "body": [
      "provide ${1:Context} = ${2:implementation};"
    ],
    "description": "Install a context for the enclosing scope"
  },
  "Provide Scoped": {
    "prefix": "provide-in",
    "body": [
      "provide ${1:Context} = ${2:implementation} in {",
      "\t${0:// scoped with the provided context}",
      "}"
    ],
    "description": "Install a context in a scoped block"
  },

  "Module Definition": {
    "prefix": "module",
    "body": [
      "module ${1:path.to.module} {",
      "\t${0:// module contents}",
      "}"
    ],
    "description": "Inline module definition"
  },
  "Public Module": {
    "prefix": "pub-module",
    "body": [
      "public module ${1:path.to.module} {",
      "\t${0:// public module contents}",
      "}"
    ],
    "description": "Public module"
  },
  "Mount Module": {
    "prefix": "mount",
    "body": [
      "mount ${1:path.to.module};"
    ],
    "description": "Import a module (mount)"
  },
  "Mount Items": {
    "prefix": "mount-items",
    "body": [
      "mount ${1:path.to.module}.{ ${2:Item1}, ${3:Item2} };"
    ],
    "description": "Mount selected items from a module"
  },
  "Mount As": {
    "prefix": "mount-as",
    "body": [
      "mount ${1:path.to.module} as ${2:alias};"
    ],
    "description": "Mount a module under an alias"
  },
  "Mount Glob": {
    "prefix": "mount-glob",
    "body": [
      "mount ${1:path.to.module}.*;"
    ],
    "description": "Mount all items from a module"
  },

  "Let Binding": {
    "prefix": "let",
    "body": [
      "let ${1:name}: ${2:Type} = ${3:value};"
    ],
    "description": "Let binding"
  },
  "Let Mutable": {
    "prefix": "let-mut",
    "body": [
      "let mut ${1:name}: ${2:Type} = ${3:value};"
    ],
    "description": "Mutable let binding"
  },
  "Let Inferred": {
    "prefix": "letv",
    "body": [
      "let ${1:name} = ${2:value};"
    ],
    "description": "Let binding with type inference"
  },
  "Let Destructure Tuple": {
    "prefix": "let-tuple",
    "body": [
      "let (${1:a}, ${2:b}, ${3:c}) = ${4:tuple};"
    ],
    "description": "Destructure a tuple"
  },
  "Let Destructure Record": {
    "prefix": "let-record",
    "body": [
      "let ${1:Record} { ${2:field1}, ${3:field2} } = ${4:record};"
    ],
    "description": "Destructure a record"
  },
  "Const Declaration": {
    "prefix": "const",
    "body": [
      "const ${1:NAME}: ${2:Type} = ${3:value};"
    ],
    "description": "Constant declaration"
  },
  "Static Declaration": {
    "prefix": "static",
    "body": [
      "static ${1:NAME}: ${2:Type} = ${3:value};"
    ],
    "description": "Static variable declaration"
  },

  "If Expression": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "\t${2:// true branch}",
      "} else {",
      "\t${3:// false branch}",
      "}"
    ],
    "description": "If-else expression"
  },
  "Match Expression": {
    "prefix": "match",
    "body": [
      "match ${1:expr} {",
      "\t${2:pattern} => ${3:value},",
      "\t_ => ${4:default},",
      "}"
    ],
    "description": "Match expression"
  },
  "Match on Maybe": {
    "prefix": "match-maybe",
    "body": [
      "match ${1:maybe_value} {",
      "\tSome(${2:x}) => ${3:// handle Some},",
      "\tNone => ${4:// handle None},",
      "}"
    ],
    "description": "Match on Maybe<T>"
  },
  "Match on Result": {
    "prefix": "match-result",
    "body": [
      "match ${1:result_value} {",
      "\tOk(${2:x}) => ${3:// handle Ok},",
      "\tErr(${4:e}) => ${5:// handle Err},",
      "}"
    ],
    "description": "Match on Result<T, E>"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for ${1:item} in ${2:collection} {",
      "\t${3:// loop body}",
      "}"
    ],
    "description": "For loop"
  },
  "While Loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "\t${2:// loop body}",
      "}"
    ],
    "description": "While loop"
  },
  "While with Invariant": {
    "prefix": "while-invariant",
    "body": [
      "while ${1:condition}",
      "\tinvariant ${2:inv_condition}",
      "\tdecreases ${3:variant}",
      "{",
      "\t${0:// loop body}",
      "}"
    ],
    "description": "While loop with invariant + decreases"
  },
  "Loop": {
    "prefix": "loop",
    "body": [
      "loop {",
      "\t${1:// body}",
      "\tif ${2:exit} {",
      "\t\tbreak;",
      "\t}",
      "}"
    ],
    "description": "Infinite loop with break"
  },

  "Try-Recover": {
    "prefix": "try",
    "body": [
      "try {",
      "\t${1:// code that may fail}",
      "} recover {",
      "\t${2:err} => ${3:// handle error},",
      "}"
    ],
    "description": "Try-recover"
  },
  "Try-Finally": {
    "prefix": "try-finally",
    "body": [
      "try {",
      "\t${1:// code that may fail}",
      "} finally {",
      "\t${2:// always-run cleanup}",
      "}"
    ],
    "description": "Try-finally"
  },
  "Try-Recover-Finally": {
    "prefix": "try-full",
    "body": [
      "try {",
      "\t${1:// code that may fail}",
      "} recover {",
      "\t${2:err} => ${3:// handle error},",
      "} finally {",
      "\t${4:// cleanup}",
      "}"
    ],
    "description": "Full try-recover-finally"
  },
  "Defer": {
    "prefix": "defer",
    "body": [
      "defer ${1:cleanup}();"
    ],
    "description": "Defer scoped cleanup (runs on scope exit)"
  },
  "Errdefer": {
    "prefix": "errdefer",
    "body": [
      "errdefer ${1:cleanup}();"
    ],
    "description": "Error-path-only cleanup"
  },
  "Ok": {
    "prefix": "ok",
    "body": [
      "Ok(${1:value})"
    ],
    "description": "Result::Ok"
  },
  "Err": {
    "prefix": "err",
    "body": [
      "Err(${1:error})"
    ],
    "description": "Result::Err"
  },

  "Async Block": {
    "prefix": "async",
    "body": [
      "async {",
      "\t${1:// async body}",
      "}"
    ],
    "description": "Async block"
  },
  "Await": {
    "prefix": "await",
    "body": [
      "${1:future}.await"
    ],
    "description": "Await a future"
  },
  "Spawn Task": {
    "prefix": "spawn",
    "body": [
      "spawn {",
      "\t${1:// concurrent task}",
      "}"
    ],
    "description": "Spawn a concurrent task"
  },
  "Nursery (Structured Concurrency)": {
    "prefix": "nursery",
    "body": [
      "nursery {",
      "\tspawn ${1:task_a}();",
      "\tspawn ${2:task_b}();",
      "\t${3:// all children joined at nursery exit}",
      "}"
    ],
    "description": "Structured concurrency scope"
  },
  "Select": {
    "prefix": "select",
    "body": [
      "select {",
      "\t${1:result_a} = ${2:future_a}.await => ${3:// handle A},",
      "\t${4:result_b} = ${5:future_b}.await => ${6:// handle B},",
      "}"
    ],
    "description": "Race multiple futures"
  },
  "Async Closure": {
    "prefix": "async-closure",
    "body": [
      "async |${1:params}| {",
      "\t${2:// async body}",
      "}"
    ],
    "description": "Async closure"
  },

  "List Literal": {
    "prefix": "list",
    "body": [
      "let ${1:name}: List<${2:T}> = [${3:elements}];"
    ],
    "description": "List literal"
  },
  "Empty List": {
    "prefix": "list-new",
    "body": [
      "let ${1:name}: List<${2:T}> = List.new();"
    ],
    "description": "Empty list via constructor"
  },
  "Map Literal": {
    "prefix": "map",
    "body": [
      "let ${1:name}: Map<${2:K}, ${3:V}> = {",
      "\t${4:key} => ${5:value},",
      "};"
    ],
    "description": "Map literal"
  },
  "Empty Map": {
    "prefix": "map-new",
    "body": [
      "let ${1:name}: Map<${2:K}, ${3:V}> = Map.new();"
    ],
    "description": "Empty map via constructor"
  },
  "Set Literal": {
    "prefix": "set",
    "body": [
      "let ${1:name}: Set<${2:T}> = { ${3:elements} };"
    ],
    "description": "Set literal"
  },
  "Some": {
    "prefix": "some",
    "body": [
      "Some(${1:value})"
    ],
    "description": "Maybe::Some"
  },
  "Maybe Value": {
    "prefix": "maybe",
    "body": [
      "let ${1:name}: Maybe<${2:T}> = Some(${3:value});"
    ],
    "description": "Maybe<T> binding"
  },
  "Result Value": {
    "prefix": "result",
    "body": [
      "let ${1:name}: Result<${2:Ok}, ${3:Err}> = Ok(${4:value});"
    ],
    "description": "Result<T, E> binding"
  },
  "Heap Allocation": {
    "prefix": "heap",
    "body": [
      "let ${1:name}: Heap<${2:T}> = Heap(${3:value});"
    ],
    "description": "Heap-owned box (unique)"
  },
  "Shared Reference": {
    "prefix": "shared",
    "body": [
      "let ${1:name}: Shared<${2:T}> = Shared(${3:value});"
    ],
    "description": "Atomically reference-counted share"
  },
  "List Comprehension": {
    "prefix": "listcomp",
    "body": [
      "[${1:expr} for ${2:x} in ${3:collection} if ${4:condition}]"
    ],
    "description": "List comprehension"
  },

  "Closure": {
    "prefix": "closure",
    "body": [
      "|${1:params}| ${2:body}"
    ],
    "description": "Closure"
  },
  "Closure with Block": {
    "prefix": "closure-block",
    "body": [
      "|${1:params}| {",
      "\t${2:// body}",
      "}"
    ],
    "description": "Closure with block body"
  },
  "Closure with Type": {
    "prefix": "closure-typed",
    "body": [
      "|${1:params}| -> ${2:ReturnType} {",
      "\t${3:// body}",
      "}"
    ],
    "description": "Closure with explicit return type"
  },

  "Checked Reference": {
    "prefix": "ref-checked",
    "body": [
      "&checked ${1:value}"
    ],
    "description": "CBGR Tier 1 — 0 ns, compiler-proven safe"
  },
  "Unsafe Reference": {
    "prefix": "ref-unsafe",
    "body": [
      "&unsafe ${1:value}"
    ],
    "description": "CBGR Tier 2 — requires manual safety proof"
  },
  "Mutable Reference": {
    "prefix": "ref-mut",
    "body": [
      "&mut ${1:value}"
    ],
    "description": "Mutable reference"
  },

  "Assert": {
    "prefix": "assert",
    "body": [
      "assert(${1:condition});"
    ],
    "description": "Runtime assertion"
  },
  "Assert Equal": {
    "prefix": "assert-eq",
    "body": [
      "assert_eq(${1:left}, ${2:right});"
    ],
    "description": "Assert equality (no bang in Verum)"
  },
  "Assert Not Equal": {
    "prefix": "assert-ne",
    "body": [
      "assert_ne(${1:left}, ${2:right});"
    ],
    "description": "Assert inequality (no bang in Verum)"
