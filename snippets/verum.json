      "\t// Arrange",
      "\tlet ${2:fixture} = ${3:setup};",
      "\t",
      "\t// Act",
      "\tlet result = ${4:action};",
      "\t",
      "\t// Assert",
      "\tassert_eq(result, ${5:expected});",
      "}"
    ],
    "description": "Test with arrange/act/assert"
  },
  "Property Test": {
    "prefix": "test-property",
    "body": [
      "@test(property, iterations: ${1:100})",
      "fn prop_${2:name}(${3:x}: ${4:Type}) {",
      "\t${5:// property that should always hold}",
      "}"
    ],
    "description": "Property-based test"
  },
  "Benchmark": {
    "prefix": "bench",
    "body": [
